# .env.example — copy to .env and fill in values; .env is gitignored
# Source before running any lifecycle script:
#   source .env && ./deploy.sh
#   source .env && ./tenant-add.sh <tenant> <env>

# ── Kubernetes ────────────────────────────────────────────────────────────────
# Path to kubeconfig for the k3s cluster (defaults to ./kubeconfig in repo root)
KUBECONFIG=./kubeconfig

# ── Hetzner Cloud ─────────────────────────────────────────────────────────────
# Cloud API token — used by CCM and hetzner-k3s CLI for server/LB management
HCLOUD_TOKEN=your-hetzner-cloud-api-token
# DNS API token — used by configure-dns.sh to manage DNS records
# Create at: https://dns.hetzner.com → API Tokens (separate from Cloud token)
HETZNER_DNS_TOKEN=your-hetzner-dns-api-token

# ── Wasabi S3 ─────────────────────────────────────────────────────────────────
WASABI_ACCESS_KEY=your-wasabi-access-key
WASABI_SECRET_KEY=your-wasabi-secret-key
WASABI_REGION=us-east-1
# Bucket for CNPG WAL archiving and base backups
WASABI_BUCKET=dotcms-pg-backup
# Bucket for dotCMS binary assets (served via CSI-S3 / geesefs)
WASABI_S3FUSE_BUCKET=dotcms-assets
# Bucket for Loki log aggregation storage
WASABI_LOKI_BUCKET=dotcms-loki-logs

# ── Valkey (shared Redis-compatible cache) ────────────────────────────────────
# Optional: set a password to enable Valkey auth for in-cluster traffic.
# If left empty, auth is disabled (safe for internal-only k8s cluster network).
# Must be set before running deploy.sh (install-valkey.sh reads it).
# Tenant provisioning reads this to stamp per-instance connection Secrets.
VALKEY_PASSWORD=

# ── TLS / Let's Encrypt ───────────────────────────────────────────────────────
# Email registered with ACME — used by Caddy for on-demand TLS
ACME_EMAIL=ops@example.com

# ── Caddy ─────────────────────────────────────────────────────────────────────
# Base domain for all tenant routes: TENANT-ENV.botcms.cloud
# Wildcard DNS *.BASE_DOMAIN must point to the Caddy LoadBalancer IP
BASE_DOMAIN=botcms.cloud

# Container image for the caddy-webhook namespace validator (built via scripts/build-webhook.sh).
# Push to any registry accessible from the cluster (GHCR, Docker Hub, private registry).
WEBHOOK_IMAGE=ghcr.io/dotcms/caddy-webhook:latest
# FQDN for the Caddy admin API endpoint (must resolve to cluster LB IP)
CADDY_ADMIN_DOMAIN=caddy-admin.botcms.cloud
# BasicAuth credentials for internal dashboards (observe.BASE_DOMAIN, manage.BASE_DOMAIN)
# CADDY_ADMIN_PASSWORD is hashed with bcrypt at deploy time — never stored as plaintext in k8s
CADDY_ADMIN_USER=admin
CADDY_ADMIN_PASSWORD=change-me-strong-password

# ── OpenSearch ────────────────────────────────────────────────────────────────
# Admin credentials for the shared OpenSearch cluster (opster operator default user: admin)
OPENSEARCH_ADMIN_USER=admin
OPENSEARCH_ADMIN_PASSWORD=change-me-strong-password

# ── Monitoring ────────────────────────────────────────────────────────────────
# Grafana admin password — Grafana exposed at observe.BASE_DOMAIN via Caddy ingress
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
